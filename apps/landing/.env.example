# Marketing site — optional overrides (copy to .env.local)

# GitHub repository URL (links in nav, footer; also used to build the releases API URL below)
# VITE_GITHUB_REPO_URL=https://github.com/your-org/MySTT

# Override GitHub REST API URL for GET …/releases/latest (defaults to api.github.com/repos/{owner}/{repo}/releases/latest)
# VITE_GITHUB_RELEASES_API_URL=https://api.github.com/repos/dhyey2075/MySTT/releases/latest

# Pin a direct installer URL — skips the GitHub API on "Download" (useful for forks or offline builds)
# VITE_DOWNLOAD_URL=https://github.com/your-org/MySTT/releases/download/build-3/MySTT-0.0.1-Setup.exe
