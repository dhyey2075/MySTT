{
  "name": "@mystt/desktop",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "MySTT — offline speech-to-text desktop app",
  "author": "MySTT Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/mystt/MySTT.git",
    "directory": "apps/desktop"
  },
  "homepage": "https://github.com/mystt/MySTT#readme",
  "bugs": {
    "url": "https://github.com/mystt/MySTT/issues"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --dir --win --x64",
    "dist:installer": "electron-vite build && electron-builder --win nsis --x64 --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@mystt/core-pipeline": "workspace:*",
    "@mystt/ipc-contract": "workspace:*",
    "@mystt/ui": "workspace:*",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@fontsource-variable/inter": "^5.2.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.7.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.mystt.desktop",
    "productName": "MySTT",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/runtime-manifest.json",
        "to": "."
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "icon": "resources/icons/logo.png",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "forceCodeSigning": false,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
